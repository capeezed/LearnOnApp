<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/learnon_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/learnon_surface"
        android:elevation="4dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvVoltar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Voltar"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/learnon_primary"
            android:padding="8dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Pagamento"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/learnon_text"
            android:gravity="end" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Comprar microcurso"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/learnon_text"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Informe o ID de um curso publicado para abrir o checkout seguro do Mercado Pago."
            android:textSize="14sp"
            android:textColor="@color/learnon_text_muted"
            android:layout_marginBottom="24dp" />

        <EditText
            android:id="@+id/etCourseId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="ID do curso"
            android:inputType="number"
            android:textColor="@color/learnon_text"
            android:textColorHint="@color/learnon_text_muted"
            android:background="@drawable/input_bg"
            android:padding="16dp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnComprar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Comprar curso"
            android:textColor="@color/learnon_on_primary"
            android:background="@drawable/btn_primary" />

        <TextView
            android:id="@+id/tvResultado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/learnon_text_muted"
            android:paddingTop="24dp" />

    </LinearLayout>

</LinearLayout>
