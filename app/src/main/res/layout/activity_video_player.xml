<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/learnon_background"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/learnon_surface"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingEnd="24dp">

        <TextView
            android:id="@+id/tvVoltar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="&lt;"
            android:textColor="@color/learnon_text"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTituloVideo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:maxLines="1"
            android:text="Aula"
            android:textColor="@color/learnon_text"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="248dp"
        android:background="@color/black"
        app:show_buffering="when_playing"
        app:use_controller="true" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="Sobre esta aula"
            android:textColor="@color/learnon_text"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDescricao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/course_card_bg"
            android:padding="18dp"
            android:textColor="@color/learnon_text_muted"
            android:textSize="14sp" />

    </LinearLayout>
</LinearLayout>
