<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/learnon_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@color/learnon_surface"
            android:elevation="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingEnd="24dp">

            <TextView
                android:id="@+id/tvVoltar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="&lt;"
                android:textColor="@color/learnon_text"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:text="Pedir Curso"
                android:textColor="@color/learnon_text"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="22dp"
                android:background="@drawable/course_header_bg"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Transforme uma duvida em curso"
                    android:textColor="@color/learnon_text"
                    android:textSize="23sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Descreva o tema e o formato ideal para voce."
                    android:textColor="@color/learnon_text_muted"
                    android:textSize="14sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/course_card_bg"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Titulo do curso"
                    android:textColor="@color/learnon_text"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etTitulo"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="18dp"
                    android:background="@drawable/input_bg"
                    android:hint="Ex: Como usar async/await"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="@color/learnon_text"
                    android:textColorHint="@color/learnon_text_muted"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Descricao"
                    android:textColor="@color/learnon_text"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etDescricao"
                    android:layout_width="match_parent"
                    android:layout_height="122dp"
                    android:layout_marginBottom="18dp"
                    android:background="@drawable/input_bg"
                    android:gravity="top"
                    android:hint="Descreva sua duvida em detalhes..."
                    android:inputType="textMultiLine"
                    android:paddingStart="16dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="16dp"
                    android:textColor="@color/learnon_text"
                    android:textColorHint="@color/learnon_text_muted"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Area / Tema"
                    android:textColor="@color/learnon_text"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etTopico"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="18dp"
                    android:background="@drawable/input_bg"
                    android:hint="Ex: JavaScript, Design, Marketing"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="@color/learnon_text"
                    android:textColorHint="@color/learnon_text_muted"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Formato preferido"
                    android:textColor="@color/learnon_text"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="18dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnAoVivo"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/btn_format_choice"
                        android:text="Ao vivo"
                        android:textColor="@color/format_choice_text"
                        android:textSize="13sp" />

                    <Button
                        android:id="@+id/btnGravado"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/btn_format_choice"
                        android:text="Gravado"
                        android:textColor="@color/format_choice_text"
                        android:textSize="13sp" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvErro"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:gravity="center"
                    android:text=""
                    android:textColor="@color/learnon_error"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvSucesso"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:gravity="center"
                    android:text=""
                    android:textColor="@color/learnon_success"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/btnEnviar"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/btn_primary"
                    android:text="Enviar pedido"
                    android:textColor="@color/learnon_text"
                    android:textSize="16sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
