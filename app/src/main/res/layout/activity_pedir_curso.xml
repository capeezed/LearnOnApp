<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f0ebe3"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="#ffffff"
            android:elevation="4dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvVoltar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← "
                android:textSize="20sp"
                android:textColor="#1c2b3a"
                android:padding="8dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Pedir Curso"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1c2b3a" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Titulo do curso"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1c2b3a"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etTitulo"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Ex: Como usar async/await"
                android:background="@drawable/input_bg"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="#1c2b3a"
                android:textColorHint="#7a7060"
                android:textSize="15sp"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Descricao"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1c2b3a"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etDescricao"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:hint="Descreva sua duvida em detalhes..."
                android:background="@drawable/input_bg"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:textColor="#1c2b3a"
                android:textColorHint="#7a7060"
                android:textSize="15sp"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Area / Tema"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1c2b3a"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etTopico"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Ex: JavaScript, Design, Marketing"
                android:background="@drawable/input_bg"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="#1c2b3a"
                android:textColorHint="#7a7060"
                android:textSize="15sp"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Formato preferido"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1c2b3a"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <Button
                    android:id="@+id/btnAoVivo"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Ao vivo"
                    android:textSize="13sp"
                    android:background="@drawable/btn_outline"
                    android:textColor="#1c2b3a" />

                <Button
                    android:id="@+id/btnGravado"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Gravado"
                    android:textSize="13sp"
                    android:background="@drawable/btn_outline"
                    android:textColor="#1c2b3a" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvErro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#d64e2a"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginBottom="16dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvSucesso"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#2a7a6e"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginBottom="16dp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnEnviar"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Enviar pedido"
                android:textColor="#ffffff"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/btn_primary" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>